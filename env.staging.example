# Staging Environment
# Copy this file to .env.staging

# Environment type
VITE_ENV=staging

# API Base URL for your staging backend
VITE_API_BASE_URL=https://staging-api.yourdomain.com/api

# Application title
VITE_APP_TITLE=Sorigin AMS (Staging)

# Disable debug mode for staging
VITE_DEBUG=false

# Additional staging-specific variables
# VITE_ANALYTICS_ID=staging-analytics-id
# VITE_SENTRY_DSN=staging-sentry-dsn 