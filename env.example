# Environment Configuration Example
# Copy this file to .env.dev-local, .env.development, .env.staging, or .env.production
# and customize the values for your environment

# Environment type (local, development, staging, production)
# This is optional - the app will auto-detect based on hostname/port
VITE_ENV=local

# API Base URL for your backend
# This will override the default URL for this environment
VITE_API_BASE_URL=http://localhost:3000/api

# Application title
# This will override the default title for this environment
VITE_APP_TITLE=Personal Portal (Local)

# Enable debug mode (true/false)
# This will override the default debug setting for this environment
VITE_DEBUG=true

# Additional environment-specific variables
# VITE_FEATURE_FLAG_NEW_UI=false
# VITE_ANALYTICS_ID=your-analytics-id
# VITE_SENTRY_DSN=your-sentry-dsn 