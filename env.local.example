# Local Development Environment
# Copy this file to .env.dev-local

# Environment type (optional - auto-detected from localhost)
VITE_ENV=local

# API Base URL for your local backend
VITE_API_BASE_URL=http://localhost:3000/api

# Application title
VITE_APP_TITLE=Sorigin AMS (Local)

# Enable debug mode for development
VITE_DEBUG=true

# Additional local-specific variables
# VITE_MOCK_API=true
# VITE_DEV_TOOLS=true 