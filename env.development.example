# Development Environment
# Copy this file to .env.development

# Environment type
VITE_ENV=development

# API Base URL for your development backend
VITE_API_BASE_URL=https://dev-api.yourdomain.com/api

# Application title
VITE_APP_TITLE=Sorigin AMS (Development)

# Enable debug mode for development
VITE_DEBUG=true

# Additional development-specific variables
# VITE_ANALYTICS_ID=dev-analytics-id
# VITE_SENTRY_DSN=dev-sentry-dsn 