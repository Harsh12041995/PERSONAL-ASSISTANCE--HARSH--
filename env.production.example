# Production Environment
# Copy this file to .env.production

# Environment type
VITE_ENV=production

# API Base URL for your production backend
VITE_API_BASE_URL=https://api.yourdomain.com/api

# Application title
VITE_APP_TITLE=Sorigin AMS

# Disable debug mode for production
VITE_DEBUG=false

# Additional production-specific variables
# VITE_ANALYTICS_ID=prod-analytics-id
# VITE_SENTRY_DSN=prod-sentry-dsn 