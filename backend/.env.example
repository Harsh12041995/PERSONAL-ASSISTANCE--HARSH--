# backend/.env.example — copy to backend/.env and fill in.
# Validated at boot by config/env.js (the server refuses to start if invalid).

# Runtime
NODE_ENV=development
PORT=5001
LOG_LEVEL=info

# Database (required)
MONGODB_URI=mongodb://127.0.0.1:27017/personal

# Auth (required; JWT_SECRET must be >= 16 chars)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Security
# Comma-separated browser origins allowed to call the API.
# Leave empty in dev to allow all; set explicitly in production.
CORS_ORIGINS=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Agent runtime (local-first; used from Phase 1 onward)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
QDRANT_URL=http://127.0.0.1:6333

# ── Staff agents & ingestion (CEO OS layer) ──────────────────────────────────
# Enable the scheduler ONLY on the long-running tier (Docker), never serverless.
# Runs: 07:00 morning brief, 02:00 ghostwriter, Fri 16:00 kill review, hourly RSS.
ENABLE_SCHEDULER=false

# Portfolio importer + GitHub activity.
# GITHUB_USER alone imports your PUBLIC repos. Add a GITHUB_TOKEN (classic PAT
# with `repo` scope, or fine-grained read-only Contents) to include PRIVATE repos
# and raise the rate limit. For webhook auto-registration the token also needs
# `admin:repo_hook`. Never commit a real token.
GITHUB_USER=
GITHUB_TOKEN=

# Public HTTPS URL of the DEPLOYED backend (no trailing slash), used to register
# GitHub webhooks so live push/PR/issue activity flows into the portfolio.
# e.g. https://api.yourdomain.com
PUBLIC_BASE_URL=

# Optional: shared secret to HMAC-verify inbound GitHub webhook payloads.
GITHUB_WEBHOOK_SECRET=
